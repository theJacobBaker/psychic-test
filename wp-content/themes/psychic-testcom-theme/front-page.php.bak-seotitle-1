  },
  {
    id: "format",
    prompt: "How do you want to receive what's said?",
    sub: "Readers offer different formats for different needs.",
    type: "choice",
    options: [
      { v: "written", label: "In writing — I want to re-read it later" },
      { v: "voice", label: "Out loud — so I can hear the tone" },
      { v: "slow", label: "Slowly, in a long-form session" },
      { v: "short", label: "Short and specific — under 15 minutes" },
    ],
  },
  {
    id: "history",
    prompt: "Have you had a reading before?",
    sub: "",
    type: "choice",
    options: [
      { v: "never", label: "No — this would be my first" },
      { v: "once", label: "Once or twice, years ago" },
      { v: "sometimes", label: "Occasionally — when I need to" },
      { v: "regular", label: "Yes, regularly" },
    ],
  },
  {
    id: "skeptic",
    prompt: "On a quiet day, how skeptical would you say you are?",
    sub: "Being skeptical is welcome. We read for skeptics often.",
    type: "scale",
  },
  {
    id: "timing",
    prompt: "If something were true, when would you want to know?",
    sub: "",
    type: "choice",
    options: [
      { v: "now", label: "Immediately — even if it's hard" },
      { v: "soon", label: "Soon — but gently" },
      { v: "ready", label: "When I'm actually ready to act" },
      { v: "never", label: "Only if I can do something about it" },
    ],
  },
];

const ARCHETYPES = {
  seeker: {
    name: "The Seeker",
    kicker: "Curious, gently skeptical, open to the long answer",
    body: [
      "You ask questions for the quality of the question, not the comfort of the answer. You're not looking for a prophecy — you're looking for a clearer conversation with yourself.",
      "A reader who listens well and doesn't oversell is the right fit. You'll get the most from written or long-form sessions where you can revisit the words.",
    ],
    traits: { ["Best format"]: "Written chat", ["Session length"]: "45–60 min", ["Style"]: "Reflective" },
    recs: [0, 2],
  },
  navigator: {
    name: "The Navigator",
    kicker: "Practical, decisive, wants the map not the mystery",
    body: [
      "You're carrying a decision, and what you need isn't reassurance — it's another angle. You already know most of what you need; you're checking your work.",
      "A grounded, experience-based reader who works with clarity tools will serve you best. Skip anything that feels theatrical.",
    ],
    traits: { ["Best format"]: "Voice call", ["Session length"]: "20–30 min", ["Style"]: "Grounded" },
    recs: [1, 4],
  },
  keeper: {
    name: "The Keeper",
    kicker: "Carrying something tender and worth holding carefully",
    body: [
      "You're in a moment where what's needed is less information and more company. A reader who has experience with grief, transitions, or ambiguity will meet you where you are.",
      "You'll want someone patient, reverent, and unhurried. Many Keepers also find dream work meaningful.",
    ],
    traits: { ["Best format"]: "Long session", ["Session length"]: "60–90 min", ["Style"]: "Reverent" },
    recs: [3, 5],
  },
  listener: {
    name: "The Quiet Listener",
    kicker: "Attuned, patient, reads between lines",
    body: [
      "You don't need a reader to be louder than you are. You're looking for someone whose presence matches your own — someone who trusts what isn't said.",
      "Intuitive or empathic practitioners are often the best fit. Readings that feel like good conversations tend to land for you.",
    ],
    traits: { ["Best format"]: "Written chat", ["Session length"]: "30–45 min", ["Style"]: "Empathic" },
    recs: [0, 7],
  },
};

const PSYCHICS = [
  { id:0, name:"Elena Marsh", meta:"Love & Relationships · 19 yrs", photo:"https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=400&q=80", match:92 },
  { id:1, name:"Matilda Oak", meta:"Career & Decisions · 14 yrs", photo:"https://images.unsplash.com/photo-1580489944761-15a19d654956?w=400&q=80", match:88 },
  { id:2, name:"Nova Bennett", meta:"Tarot · Intuitive · 9 yrs", photo:"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400&q=80", match:85 },
  { id:3, name:"Ruth Callahan", meta:"Mediumship & Grief · 27 yrs", photo:"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&q=80", match:94 },
  { id:4, name:"Priya Shah", meta:"Vedic Astrology · 18 yrs", photo:"https://images.unsplash.com/photo-1531123897727-8f129e1688ce?w=400&q=80", match:87 },
  { id:5, name:"Celeste Amari", meta:"Dreams & Shadow · 16 yrs", photo:"https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=400&q=80", match:90 },
  { id:6, name:"Isadora Vale", meta:"Natal Charts · 22 yrs", photo:"https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=80", match:83 },
  { id:7, name:"August Wren", meta:"Energy & Empath · 11 yrs", photo:"https://images.unsplash.com/photo-1607746882042-944635dfe10e?w=400&q=80", match:86 },
];

function decideArchetype(answers) {
  const topic = answers.carrying;
  const skeptic = answers.skeptic ?? 4;
  const openness = answers.openness ?? 4;
  if (topic === "grief") return "keeper";
  if (topic === "career" || answers.how_decide === "logic") return "navigator";
  if (skeptic >= 5 || openness <= 3) return "seeker";
  return "listener";
}

function Intro({ onStart }) {
  return (
    <section className="intro fade-in">
      <span className="eyebrow"><span className="dot"/>Free · 7 questions · 2 minutes</span>
      <h1>A quiet test<br/><em>to find your reading.</em></h1>
      <p className="lede">Seven thoughtful questions, an honest result, and a handful of practitioners we'd actually recommend for what you're carrying.</p>
      <button className="btn btn-primary" onClick={onStart}>Begin the test
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
      <div className="intro-meta">
        <div><strong>412,870</strong><span>tests taken</span></div>
        <div><strong>2 min</strong><span>average time</span></div>
        <div><strong>Free</strong><span>no sign-up</span></div>
      </div>
      <div className="intro-trust">
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.6" strokeLinecap="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>Anonymous</span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.6" strokeLinecap="round"><path d="M12 3l8 3v5c0 5-3.4 9.3-8 10-4.6-.7-8-5-8-10V6z"/></svg>No data shared</span>
        <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.6" strokeLinecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>Results instant</span>
      </div>
    </section>
  );
}

function Question({ q, idx, total, value, onAnswer, onNext, onBack }) {
  const letters = ["A","B","C","D","E","F"];
  return (
    <section className="quiz fade-in" key={q.id}>
      <div className="step-num">Question {idx+1} of {total}</div>
      <h2 className="question" dangerouslySetInnerHTML={{__html: q.prompt.replace(/\*(.+?)\*/g, '<em>$1</em>')}} />
      {q.sub && <p className="question-sub">{q.sub}</p>}

      {q.type === "choice" && (
        <div className="options">
          {q.options.map((o, i) => (
            <button key={o.v} className={"option" + (value === o.v ? " selected" : "")} onClick={() => onAnswer(o.v)}>
              <span className="option-letter">{letters[i]}</span>
              <span className="option-label">{o.label}</span>
            </button>
          ))}
        </div>
      )}
      {q.type === "scale" && (
        <>
          <div className="scale">
            {[1,2,3,4,5,6,7].map(n => (
              <button key={n} className={"scale-pt" + (value === n ? " selected" : "")} onClick={() => onAnswer(n)}>{n}</button>
            ))}
          </div>
          <div className="scale-labels">
            <span>Not at all</span><span>Completely</span>
          </div>
        </>
      )}

      <div className="nav-row">
        <button className="btn btn-ghost" onClick={onBack} style={{visibility: idx === 0 ? "hidden" : "visible"}}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
          Previous
        </button>
        <button className="btn btn-primary" onClick={onNext} disabled={value === undefined} style={{opacity: value === undefined ? 0.4 : 1, pointerEvents: value === undefined ? "none" : "auto"}}>
          {idx === total - 1 ? "See my result" : "Continue"}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </div>
    </section>
  );
}

function Result({ answers, onRestart }) {
  const key = decideArchetype(answers);
  const a = ARCHETYPES[key];
  const recs = a.recs.map(i => PSYCHICS[i]);
  return (
    <section className="result show fade-in">
      <div className="result-eyebrow">Your result</div>
      <h2 className="result-title">You're <em>{a.name}.</em></h2>
      <p className="result-sub">{a.kicker}.</p>

      <div className="archetype-card">
        <div className="archetype-header">
          <div className="archetype-glyph"/>
          <div>
            <h3 className="archetype-name">{a.name}</h3>
            <div className="archetype-kicker">{a.kicker}</div>
          </div>
        </div>
        <div className="archetype-body">
          {a.body.map((p,i) => <p key={i}>{p}</p>)}
        </div>
        <div className="traits">
          {Object.entries(a.traits).map(([k,v]) => (
            <div key={k}>
              <div className="trait-label">{k}</div>
              <div className="trait-val">{v}</div>
            </div>
          ))}
        </div>
      </div>

      <div className="recommend">
        <h3>Practitioners we'd suggest for you</h3>
        <p>Chosen based on your answers. Each has a strong record with {a.name.toLowerCase()}s.</p>
        <div className="rec-grid">
          {recs.map(p => (
            <a key={p.id} className="rec-card">
              <div className="rec-photo" style={{backgroundImage:`url(${p.photo})`}}/>
              <div className="rec-body">
                <div className="rec-name">{p.name}</div>
                <div className="rec-meta">{p.meta}</div>
              </div>
              <div className="rec-match">{p.match}% match</div>
            </a>
          ))}
        </div>
      </div>

      <div className="result-cta">
        <div className="result-cta-text">
          <h4>Your first five minutes are free.</h4>
          <p>Start a session with either reader. End anytime — no charge if it's not right.</p>
        </div>
        <button className="btn btn-primary">Start a session</button>
      </div>

      <div style={{textAlign:"center",marginTop:40}}>
        <button className="btn btn-ghost" onClick={onRestart}>Retake the test</button>
      </div>
    </section>
  );
}

function App() {
  const [stage, setStage] = useState("intro"); // intro | quiz | result
  const [idx, setIdx] = useState(0);
  const [answers, setAnswers] = useState({});

  const onAnswer = (val) => setAnswers(a => ({...a, [QUESTIONS[idx].id]: val}));
  const onNext = () => {
    if (idx === QUESTIONS.length - 1) setStage("result");
    else setIdx(idx + 1);
  };
  const onBack = () => setIdx(Math.max(0, idx - 1));

  const currentQ = QUESTIONS[idx];
  const currentVal = answers[currentQ?.id];
  const pct = stage === "quiz" ? ((idx + 1) / QUESTIONS.length) * 100 : stage === "result" ? 100 : 0;

  return (
    <>
      <header className="header">
        <div className="container header-inner">
          <div className="logo"><span className="logo-mark"/>Inner Compass</div>
          <div className="header-meta">A free test by Clairo</div>
        </div>
      </header>

      {stage !== "intro" && (
        <div className="progress-wrap">
          <div className="container">
            <div className="progress-label">
              <span>{stage === "result" ? "Complete" : `Question ${idx+1} / ${QUESTIONS.length}`}</span>
              <span>{Math.round(pct)}%</span>
            </div>
            <div className="progress-bar"><div className="progress-fill" style={{width: pct + "%"}}/></div>
          </div>
        </div>
      )}

      <main className="container">
        {stage === "intro" && <Intro onStart={() => setStage("quiz")}/>}
        {stage === "quiz" && <Question q={currentQ} idx={idx} total={QUESTIONS.length} value={currentVal} onAnswer={onAnswer} onNext={onNext} onBack={onBack}/>}
        {stage === "result" && <Result answers={answers} onRestart={() => {setStage("intro"); setIdx(0); setAnswers({});}}/>}
      </main>

      <footer className="footer container">
        <span>© 2026 Inner Compass · A test by Clairo</span>
        <span>Anonymous · No sign-up · Your answers aren't stored</span>
      </footer>
    </>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
<?php wp_footer(); ?>
</body>
</html>
