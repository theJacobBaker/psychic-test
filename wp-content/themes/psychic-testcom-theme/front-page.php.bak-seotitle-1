<script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>

<script type="text/babel">
const { useState, useEffect } = React;

const QUESTIONS = [
  {
    id: "carrying",
    prompt: "What are you carrying with you today?",
    sub: "There's no wrong answer. Pick the one that feels closest.",
    type: "choice",
    options: [
      { v: "love", label: "A question about a relationship" },
      { v: "career", label: "A choice about work or direction" },
      { v: "grief", label: "Grief, or connection with someone I miss" },
      { v: "self", label: "A feeling I can't yet name" },
      { v: "future", label: "Curiosity about what's coming" },
    ],
  },
  {
    id: "how_decide",
    prompt: "When something matters, how do you usually *decide?*",
    sub: "This tells us which kind of reading will land for you.",
    type: "choice",
    options: [
      { v: "logic", label: "I make a list. I think it through." },
      { v: "gut", label: "I listen to my gut, eventually." },
      { v: "others", label: "I talk it out with people I trust." },
      { v: "signs", label: "I wait for something to become clear." },
